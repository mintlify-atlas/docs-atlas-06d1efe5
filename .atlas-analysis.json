  "keyFeatures": [
    "Multi-agent swarm intelligence simulation",
    "Knowledge graph construction with GraphRAG",
    "Long-term memory management with Zep Cloud",
    "Social media simulation powered by OASIS",
    "Interactive AI-powered report generation",
    "Real-time agent interview and interaction",
    "Support for multiple prediction scenarios (finance, opinion, stories)",
    "Docker deployment with environment configuration"
  ],
  "publicApiSurface": [
    "POST /api/graph/build - Build knowledge graph from seed data",
    "GET /api/graph/project/{project_id} - Get project details",
    "POST /api/graph/ontology/generate - Generate ontology from text",
    "GET /api/simulation/entities/{graph_id} - Get graph entities",
    "POST /api/simulation/profiles/generate - Generate agent profiles",
    "POST /api/simulation/start - Start multi-agent simulation",
    "GET /api/simulation/status/{simulation_id} - Get simulation status",
    "POST /api/simulation/interview - Interview simulation agents",
    "POST /api/report/generate - Generate prediction report",
    "GET /api/report/{report_id} - Get report details",
    "POST /api/report/chat - Chat with report agent",
    "GET /api/report/export/{report_id} - Export report as file"
  ]
